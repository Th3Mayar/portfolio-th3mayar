---
import Item from "@/components/molecule/Item.vue";
import IconByName from "@/components/atoms/IconByName.vue";
import Button from "@/components/atoms/Button.vue";
import Typography from "@/components/atoms/Typography.vue";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Personal Info with Sidebar">
  <main class="main-container">
    <!-- Right Column (Sidebar with Icons) -->
    <aside class="icon-sidebar">
      <!-- Icon for Terminal -->
      <div class="icon-wrapper">
        <Item href="#">
          <IconByName name="Terminal" color="light" className="icon-class" />
        </Item>
      </div>

      <!-- Icon for User/Profile -->
      <div class="icon-wrapper">
        <Item href="#">
          <IconByName name="User" color="light" className="icon-class" />
        </Item>
      </div>

      <!-- Icon for Settings -->
      <div class="icon-wrapper">
        <Item href="#">
          <IconByName name="Settings" color="light" className="icon-class" />
        </Item>
      </div>
    </aside>

    <!-- Left Sidebar (Personal Info) -->
    <aside class="sidebar">
      <section class="info-section">
        <Typography variant="FiraCode" as="h5" color="light" caseType="upper">
          personal-info
        </Typography>

        <!-- Personal Info Items -->
        <ul>
          <Item title="bio" href="#" class="personal-item">
            <IconByName name="Folder" color="light" className="icon" />
          </Item>
          <Item title="interests" href="#" class="personal-item">
            <IconByName name="Folder" color="light" className="icon" />
          </Item>
          <Item title="education" href="#" class="personal-item">
            <IconByName name="Folder" color="light" className="icon" />
            <!-- Nested Items for High School and University -->
            <ul class="nested-items">
              <Item title="high-school" href="#" class="nested-item">
                <IconByName name="File" color="light" className="icon" />
              </Item>
              <Item title="university" href="#" class="nested-item">
                <IconByName name="File" color="light" className="icon" />
              </Item>
            </ul>
          </Item>
        </ul>
      </section>

      <!-- Contacts -->
      <section class="info-section">
        <Typography variant="FiraCode" as="h5" color="light" caseType="upper">
          contacts
        </Typography>
        <ul>
          <Item
            title="user@gmail.com"
            href="mailto:user@gmail.com"
            class="contact-item"
          >
            <IconByName name="Mail" color="light" className="icon" />
          </Item>
          <Item title="+3598246359" href="tel:+3598246359" class="contact-item">
            <IconByName name="Phone" color="light" className="icon" />
          </Item>
        </ul>
      </section>
    </aside>
  </main>
</Layout>

<style>
  .main-container {
    display: flex;
    height: 76vh;
  }

  /* Left Sidebar Styles */
  .sidebar {
    padding: 20px;
    border-right: 2px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .info-section {
    margin-bottom: 20px;
  }

  ul {
    list-style: none;
    padding-left: 0;
  }

  .personal-item,
  .contact-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nested-items {
    padding-left: 20px;
  }

  .nested-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* Right Sidebar with Icons */
  .icon-sidebar {
    width: 80px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    padding-top: 20px;
    border-right: 2px solid var(--border);
  }

  .icon-wrapper {
    margin: 20px 0;
  }

  .icon-class {
    font-size: 24px;
    color: #fff;
  }
</style>
