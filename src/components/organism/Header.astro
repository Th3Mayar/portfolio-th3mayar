---
import Item from "@/components/molecule/Item.vue";
import { useTranslations, getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { common: TCommon } = useTranslations(lang);
const { components: TComponents } = TCommon;
---

<header>
  <aside>
    <ul>
      <Item title={TComponents.name} class="item"/>
      <Item title={TComponents.hello} class="item" />
      <Item title={TComponents.aboutMe} class="item" />
      <Item title={TComponents.projects} class="item" />
      <Item title={TComponents.contactMe} class="item" />
    </ul>
  </aside>
</header>

<style>
  ul{
    display: flex;
    gap: 1rem;
  }

  aside {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    border-bottom: 2px solid var(--border);
  }
</style>
